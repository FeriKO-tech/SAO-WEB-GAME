{
  "name": "sao-web",
  "version": "0.1.0",
  "description": "Sword Art Online Web — browser MMORPG landing and account portal",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "playwright test --config=playwright-unit.config.ts",
    "test:e2e": "npm run build && playwright test tests/e2e",
    "test:e2e:ui": "npm run build && playwright test --ui",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "firebase:login": "firebase login",
    "firebase:serve": "firebase emulators:start --only hosting",
    "deploy": "npm run build && firebase deploy --only hosting,firestore:rules,firestore:indexes",
    "deploy:preview": "npm run build && firebase hosting:channel:deploy preview --expires 7d",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:indexes": "firebase deploy --only firestore:indexes",
    "seed": "node scripts/seed-firestore.mjs",
    "seed:reset": "node scripts/seed-firestore.mjs -- --reset",
    "set:staff-role": "node scripts/set-staff-role.mjs",
    "forum:recount": "node scripts/recount-forum-categories.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.19.17",
    "firebase-admin": "^13.8.0",
    "firebase-tools": "^13.29.1",
    "playwright": "^1.59.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "firebase": "^12.12.0"
  }
}
