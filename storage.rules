rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Default rule: reject all requests
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Rules for forum images
    match /forum/{imageId} {
      function isStaff() {
        return request.auth != null
            && ('role' in request.auth.token)
            && request.auth.token.role in ['staff', 'admin'];
      }

      // Anyone can view forum images
      allow read: if true;
      // Only authenticated users can upload forum images
      // Must be an image file and less than 5MB
      allow create: if request.auth != null
                  && request.resource.size < 5 * 1024 * 1024
                  && request.resource.contentType.matches('image/.*');
      // Only staff can modify/delete forum images to prevent vandalism
      allow update, delete: if isStaff();
    }

    // Rules for ticket attachments
    match /tickets/{ticketId}/{fileName} {
      function isStaff() {
        return request.auth != null
            && ('role' in request.auth.token)
            && request.auth.token.role in ['staff', 'admin'];
      }
      
      function isTicketOwner() {
        return request.auth != null 
            && firestore.get(/databases/(default)/documents/supportTickets/$(ticketId)).data.userId == request.auth.uid;
      }

      allow write: if (isTicketOwner() || isStaff())
                   && request.resource.size < 5 * 1024 * 1024;
      allow read: if isTicketOwner() || isStaff();
    }
  }
}
